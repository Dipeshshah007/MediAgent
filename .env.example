# Copy this file to ".env" and fill in ONE provider to get started.
# cp .env.example .env

# Which backend to use: groq | gemini | ollama
LLM_PROVIDER=groq

# --- Option A: Groq (free, fast, recommended) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option B: Google Gemini (free tier) ---
# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Option C: Ollama (fully local, no key) ---
# Install from https://ollama.com then: ollama pull llama3.1
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings run locally (free, no key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage
CHROMA_DIR=./data/chroma
KNOWLEDGE_DIR=./data/medical_knowledge

TEMPERATURE=0.2
